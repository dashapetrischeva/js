{
  "compilerOptions": {
    "target": "es6" /* Target JavaScript version: 'es5', 'es6', 'es2015', 'esnext', etc. */,
    "module": "commonjs" /* Module system: 'commonjs', 'amd', 'es2015', 'esnext', etc. */,
    "strict": true /* Enable all strict type-checking options. */,
    "esModuleInterop": true /* Enable interoperability with ES modules. */,
    "forceConsistentCasingInFileNames": true /* Ensure consistent file name casing within the project. */,
    "outDir": "./js" /* Output directory for the generated JavaScript files. */,
    "rootDir": "./src" /* Root directory of the TypeScript source files. */,
    "skipLibCheck": true /* Skip type checking of declaration files. */
  },
  "include": [
    "src/**/*" /* Include all files in the src directory. */
  ],
  "exclude": [
    "node_modules" /* Exclude the node_modules directory. */,
    "javascript" /* Exclude the javascript directory. */
  ]
}